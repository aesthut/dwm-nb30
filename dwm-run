#!/bin/sh
# Start-Wrapper fuer dwm. Wird von der xsession (ly) UND von ~/.xinitrc (startx)
# aufgerufen. Hier passiert der Autostart (vanilla-Weg, kein Source-Patch).

# Tastaturlayout (oesterreichisch/deutsch). Bei Bedarf anpassen/entfernen.
setxkbmap de 2>/dev/null

# Schlichte Statusbar: Datum/Uhrzeit + Akku, alle 30s in den WM-Namen.
# Laeuft im Hintergrund, endet mit der X-Session.
while :; do
    bat=""
    [ -r /sys/class/power_supply/BAT0/capacity ] && \
        bat=" | Bat $(cat /sys/class/power_supply/BAT0/capacity)%"
    xsetroot -name "$(date '+%a %d.%m. %H:%M')$bat"
    sleep 30
done &

# dwm starten (ersetzt diesen Prozess -> Session endet, wenn dwm endet).
exec dwm
